# Copy to `.env` and fill in. `.env` is .gitignored.

# Required for deploy.py / destroy.py / examples.
RUNPOD_API_KEY=

# Filled in by deploy.py after it creates the endpoint.
RUNPOD_ENDPOINT_ID=

# Optional. If you let RunPod's GitHub integration build the image, you can
# leave these blank — deploy.py only needs --image when creating a template
# from a Docker registry directly.
MINERU_IMAGE_REF=
MINERU_TEMPLATE_ID=
