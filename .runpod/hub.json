{
  "title": "MinerU 2.5 PDF Parser",
  "description": "Serverless PDF → Markdown / JSON conversion via MinerU 2.5 (1.2B VLM). Scales to zero with a 10 s idle window, ~$0.0001 per page on AMPERE_24. Three input transports (URL / base64 / mounted volume), two output formats (gzipped tarball / inline). Generic — meant to be a reusable PDF-parsing primitive for RAG and document-context systems.",
  "type": "serverless",
  "category": "language",
  "iconUrl": "",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 30,
    "gpuCount": 1,
    "gpuIds": "AMPERE_24,ADA_24,AMPERE_48,ADA_48",
    "allowedCudaVersions": ["12.4", "12.5", "12.6", "12.8"],
    "endpointType": "LB",
    "env": [
      {
        "key": "HF_HOME",
        "value": "/root/.cache/huggingface"
      },
      {
        "key": "TRANSFORMERS_OFFLINE",
        "value": "0"
      }
    ],
    "presets": [
      {
        "name": "spiky-workload-default",
        "defaults": {
          "idleTimeout": 10,
          "workersMin": 0,
          "workersMax": 3,
          "flashboot": true,
          "executionTimeoutMs": 900000,
          "scalerType": "QUEUE_DELAY",
          "scalerValue": 4
        }
      },
      {
        "name": "steady-throughput-indexer",
        "defaults": {
          "idleTimeout": 5,
          "workersMin": 1,
          "workersMax": 10,
          "flashboot": true,
          "executionTimeoutMs": 900000,
          "scalerType": "QUEUE_DELAY",
          "scalerValue": 2
        }
      },
      {
        "name": "long-single-jobs",
        "defaults": {
          "idleTimeout": 30,
          "workersMin": 0,
          "workersMax": 1,
          "flashboot": true,
          "executionTimeoutMs": 3600000,
          "scalerType": "QUEUE_DELAY",
          "scalerValue": 1
        }
      }
    ]
  }
}
